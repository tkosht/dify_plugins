{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "findings",
    "used_urls",
    "unknowns"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact",
          "status",
          "evidence",
          "recommended_update"
        ],
        "properties": {
          "artifact": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "current",
              "stale",
              "unknown"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_update": {
            "type": "string"
          }
        }
      }
    },
    "used_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^https://"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
